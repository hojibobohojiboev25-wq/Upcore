{
  "expo": {
    "name": "Upcore",
    "slug": "upcore",
    "version": "8.3.0",
    "orientation": "portrait",
    "icon": "./assets/upcore-icon.png",
    "userInterfaceStyle": "light",
    "scheme": "upcore",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "fallbackToCacheTimeout": 0
    },
    "splash": {
      "backgroundColor": "#101828"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.orzuit.upcore",
      "buildNumber": "11",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.orzuit.upcore",
      "googleServicesFile": "./google-services.json",
      "versionCode": 11,
      "adaptiveIcon": {
        "foregroundImage": "./assets/upcore-icon.png",
        "backgroundColor": "#101828"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "extra": {
      "eas": {
        "projectId": "243e899e-dc8e-411a-a7a4-0d609fbf7f7a"
      }
    },
    "owner": "hoji_elite",
    "plugins": [
      "@react-native-community/datetimepicker"
    ]
  }
}
